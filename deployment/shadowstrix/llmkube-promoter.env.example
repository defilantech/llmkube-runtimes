# Copy to ~/.config/llmkube-promoter/env (chmod 0600) on the GPU host and fill in.
# This file holds the promoter's credentials; the smoke Job never mounts it.

# Render group GID on the host (getent group render | cut -d: -f3). Passed to the
# smoke Job so the non-root container can open /dev/dri.
RENDER_GID=

# Smoke decode-throughput floor (tok/s). Set ABOVE the smoke model's CPU-only
# speed so a silent CPU fallback fails the gate; the cmd default of 40 is just a
# liveness floor. e.g. ~150 for Llama-3.2-1B on gfx1151 (GPU ~250, CPU ~60-90).
MIN_DECODE_TOKS=150

# Kubeconfig pointing at the llmkube-promoter ServiceAccount token (see rbac.yaml).
KUBECONFIG=%h/.config/llmkube-promoter/kubeconfig

# GHCR auth for promotion (retagging :stable / :b<ref>-llmkube<N>). Point at a
# docker config.json whose token has write:packages scoped to the
# llmkube-llama-vulkan package only.
DOCKER_CONFIG=%h/.config/llmkube-promoter/docker

# cosign verifies the candidate's keyless build-provenance (needs network to
# Sigstore/GHCR; the smoke Job itself is offline). No signing key in v1.
